# ============================================================
# Chief Secretary Appointment System — Environment Variables
# ============================================================
# Copy this file to .env.local for local development
# Set these in Netlify: Site Settings → Environment Variables
# ============================================================

# Supabase project URL (from Supabase → Project Settings → API)
REACT_APP_SUPABASE_URL=https://wwdfquwdqyygesmqxmlr.supabase.co

# Supabase anon/public key (from Supabase → Project Settings → API)
REACT_APP_SUPABASE_ANON_KEY=your_anon_key_here

# Admin notification email (new booking alerts go here)
REACT_APP_ADMIN_EMAIL=admin@chiefsecretary.gov.pg

# Admin dashboard password (to access the admin panel)
REACT_APP_ADMIN_PASSWORD=your_secure_password_here
